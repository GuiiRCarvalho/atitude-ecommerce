<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Atitude – Streetwear</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;800;900&display=swap"
    rel="stylesheet">

  <!-- Icons (Lucide) -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    :root {
      --bg-color: #f8f8f8;
      --text-main: #111111;
      --text-muted: #666666;
      --accent: #E53935;
      /* Vermelho vibrante/streetwear */
      --border-color: #e5e5e5;
      --white: #ffffff;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-color);
      color: var(--text-main);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* --- TOPBAR MARQUEE --- */
    .topbar {
      background: var(--text-main);
      color: var(--white);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 1px;
      padding: 10px 0;
      overflow: hidden;
      white-space: nowrap;
      position: relative;
    }

    .topbar-content {
      display: inline-block;
      animation: marquee 20s linear infinite;
    }

    .topbar-content span {
      margin: 0 30px;
    }

    @keyframes marquee {
      0% {
        transform: translateX(0);
      }

      100% {
        transform: translateX(-50%);
      }
    }

    /* --- HEADER & NAV --- */
    header {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border-color);
      position: sticky;
      top: 0;
      z-index: 100;
      transition: all 0.3s ease;
    }

    .nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 24px 60px;
      max-width: 1440px;
      margin: 0 auto;
    }

    .nav h1 {
      font-weight: 900;
      font-size: 28px;
      letter-spacing: -1px;
      text-transform: uppercase;
      cursor: pointer;
      transition: transform 0.3s ease;
    }

    .nav h1:hover {
      transform: scale(1.02);
    }

    .nav ul {
      display: flex;
      gap: 40px;
      list-style: none;
    }

    .nav a {
      text-decoration: none;
      color: var(--text-main);
      font-weight: 500;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      position: relative;
      padding-bottom: 4px;
      transition: color 0.3s ease;
    }

    /* Animação do link do menu */
    .nav a::after {
      content: '';
      position: absolute;
      width: 0;
      height: 2px;
      bottom: 0;
      left: 0;
      background-color: var(--text-main);
      transition: width 0.3s ease;
    }

    .nav a:hover::after {
      width: 100%;
    }

    .nav a.highlight {
      color: var(--accent);
    }

    .nav a.highlight::after {
      background-color: var(--accent);
    }

    /* --- HERO SECTION --- */
    .hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      min-height: calc(100vh - 120px);
      padding: 0 60px;
      gap: 60px;
      max-width: 1440px;
      margin: 0 auto;
    }

    .hero-text {
      padding: 40px 0;
      animation: fadeInUp 0.8s ease forwards;
      opacity: 0;
      transform: translateY(20px);
    }

    .badge {
      display: inline-block;
      background: var(--text-main);
      color: var(--white);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 6px 12px;
      border-radius: 4px;
      margin-bottom: 24px;
    }

    .hero-text h2 {
      font-size: clamp(3rem, 5vw, 4.5rem);
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: -2px;
      margin-bottom: 24px;
      color: var(--text-main);
    }

    .hero-text p.subtitle {
      font-size: 18px;
      color: var(--text-muted);
      margin-bottom: 32px;
      line-height: 1.5;
      max-width: 450px;
    }

    .price-container {
      margin-bottom: 40px;
      background: var(--white);
      padding: 20px 24px;
      border-radius: 12px;
      border: 1px solid var(--border-color);
      display: inline-block;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    }

    .price {
      font-size: 28px;
      font-weight: 800;
      color: var(--text-main);
    }

    .price-promo {
      font-size: 14px;
      color: var(--accent);
      font-weight: 600;
      margin-top: 4px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 18px 40px;
      background: var(--text-main);
      color: var(--white);
      text-decoration: none;
      font-weight: 600;
      font-size: 16px;
      letter-spacing: 0.5px;
      border-radius: 8px;
      transition: all 0.3s ease;
      cursor: pointer;
      border: 2px solid var(--text-main);
    }

    .btn:hover {
      background: transparent;
      color: var(--text-main);
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .hero-img-container {
      height: 100%;
      width: 100%;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: fadeIn 1s ease forwards 0.3s;
      opacity: 0;
    }

    .hero-img {
      width: 100%;
      height: 80%;
      object-fit: cover;
      border-radius: 20px;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
      transition: transform 0.5s ease;
    }

    .hero-img:hover {
      transform: scale(1.02);
    }

    /* --- BENEFITS SECTION --- */
    .benefits-wrapper {
      background: var(--white);
      border-top: 1px solid var(--border-color);
      border-bottom: 1px solid var(--border-color);
    }

    .benefits {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      max-width: 1440px;
      margin: 0 auto;
    }

    .benefit {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 40px 20px;
      text-align: center;
      border-right: 1px solid var(--border-color);
      transition: background 0.3s ease;
    }

    .benefit:last-child {
      border-right: none;
    }

    .benefit:hover {
      background: #fdfdfd;
    }

    .benefit .icon-container {
      width: 48px;
      height: 48px;
      background: var(--bg-color);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-main);
      margin-bottom: 8px;
      transition: transform 0.3s ease, background 0.3s ease;
    }

    .benefit:hover .icon-container {
      transform: translateY(-5px);
      background: var(--text-main);
      color: var(--white);
    }

    .benefit strong {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-main);
    }

    .benefit span {
      font-size: 13px;
      color: var(--text-muted);
    }

    /* --- FOOTER --- */
    footer {
      background: var(--text-main);
      color: #888;
      padding: 40px 60px;
      text-align: center;
      font-size: 13px;
      letter-spacing: 0.5px;
    }

    footer span {
      color: var(--white);
      font-weight: 600;
    }

    /* --- ANIMATIONS --- */
    @keyframes fadeInUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeIn {
      to {
        opacity: 1;
      }
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 1024px) {
      .hero {
        gap: 40px;
        padding: 0 40px;
      }

      .nav {
        padding: 20px 40px;
      }

      .benefits {
        grid-template-columns: 1fr 1fr;
      }

      .benefit {
        border-bottom: 1px solid var(--border-color);
      }

      .benefit:nth-child(2) {
        border-right: none;
      }

      .benefit:nth-child(3),
      .benefit:nth-child(4) {
        border-bottom: none;
      }
    }

    @media (max-width: 768px) {
      .nav {
        flex-direction: column;
        gap: 20px;
        padding: 20px;
      }

      .nav ul {
        gap: 20px;
        flex-wrap: wrap;
        justify-content: center;
      }

      .hero {
        grid-template-columns: 1fr;
        text-align: center;
        padding: 0 20px;
        padding-top: 40px;
      }

      .hero-text p.subtitle {
        margin: 0 auto 32px auto;
      }

      .hero-img-container {
        height: 400px;
        order: -1;
      }

      /* Imagem vem primeiro no mobile */

      .benefits {
        grid-template-columns: 1fr;
      }

      .benefit {
        border-right: none !important;
        border-bottom: 1px solid var(--border-color);
      }

      .benefit:last-child {
        border-bottom: none;
      }
    }
  </style>
</head>

<body>

  <!-- Topbar animada -->
  <div class="topbar">
    <div class="topbar-content">
      <span>🔥 FRETE GRÁTIS PARA COMPRAS ACIMA DE R$249,90</span>
      <span>•</span>
      <span>MUNDANDO A FORMA DE VER O MUNDO</span>
      <span>•</span>
      <span>NOVO DROP: OVERSIZED COLLECTION</span>
      <span>•</span>
      <span>🔥 FRETE GRÁTIS PARA COMPRAS ACIMA DE R$249,90</span>
      <span>•</span>
      <span>MUNDANDO A FORMA DE VER O MUNDO</span>
      <span>•</span>
      <span>NOVO DROP: OVERSIZED COLLECTION</span>
    </div>
  </div>

  <header>
    <nav class="nav">
      <h1>ATITUDE</h1>
      <ul>
        <li><a href="produtos.html">Produtos</a></li>
        <li><a href="#">Camisetas Oversized</a></li>
        <li><a href="#">Calças Parachute</a></li>
        <li><a href="#" class="highlight">Sale – Até 50% OFF</a></li>
      </ul>
    </nav>
  </header>

  <section class="hero">
    <div class="hero-text">
      <div class="badge">Novo Drop</div>
      <h2>ESSENTIALS<br>OVERSIZED</h2>
      <p class="subtitle">Desenhada para o caos urbano. Caimento perfeito, algodão 100% premium e atitude em cada
        costura.</p>

      <div class="price-container">
        <div class="price">R$ 179,90</div>
        <div class="price-promo">🔥 Oferta: 2 peças por R$ 299,90</div>
      </div>
      <br>

      <a href="#" class="btn">
        Comprar Agora
        <i data-lucide="arrow-right"></i>
      </a>
    </div>

    <div class="hero-img-container">
      <!-- Imagem placeholder em alta qualidade do Unsplash para dar o visual premium -->
      <img class="hero-img"
        src="https://images.unsplash.com/photo-1529374255404-311a2a4f1fd9?q=80&w=1000&auto=format&fit=crop"
        alt="Modelo usando Camiseta Oversized Atitude">
    </div>
  </section>

  <div class="benefits-wrapper">
    <section class="benefits">
      <div class="benefit">
        <div class="icon-container">
          <i data-lucide="truck"></i>
        </div>
        <strong>Frete Grátis</strong>
        <span>Em compras acima de R$249,90</span>
      </div>

      <div class="benefit">
        <div class="icon-container">
          <i data-lucide="tag"></i>
        </div>
        <strong>10% Off</strong>
        <span>Na sua primeira compra</span>
      </div>

      <div class="benefit">
        <div class="icon-container">
          <i data-lucide="refresh-ccw"></i>
        </div>
        <strong>Cashback</strong>
        <span>Ganhe 5% na próxima compra</span>
      </div>

      <div class="benefit">
        <div class="icon-container">
          <i data-lucide="credit-card"></i>
        </div>
        <strong>Parcelamento</strong>
        <span>Até 5x sem juros no cartão</span>
      </div>
    </section>
  </div>

  <footer>
    © 2026 <span>ATITUDE</span> • Todos os direitos reservados. Feito para a rua.
  </footer>

  <!-- Inicializa os ícones Lucide -->
  <script>
    lucide.createIcons();
  </script>

</body>

</html>